{
    "cSpell.language": "it,en",
    "workbench.colorTheme": "Default Dark Modern",
    "workbench.editorAssociations": {
        "*.sii": "default"
    },
    "window.confirmSaveUntitledWorkspace": false,
    "workbench.colorCustomizations": {
        "editor.background": "#0f0d0e",
        "editor.foreground": "#f5f5f5",
        "editor.lineHighlightBackground": "#1a1617",
        "editorLineNumber.foreground": "#7a7577",
        "editorLineNumber.activeForeground": "#f4bf4f",
        "editorCursor.foreground": "#f4bf4f",
        "editor.selectionBackground": "#4a0e1a99",
        "editor.selectionHighlightBackground": "#2d2728aa",
        "editor.wordHighlightBackground": "#8c1c3840",
        "editor.wordHighlightStrongBackground": "#a8284766",
        "editorBracketHighlight.foreground1": "#f4bf4f",
        "editorBracketHighlight.foreground2": "#c23456",
        "editorBracketHighlight.foreground3": "#b8b2b3",
        "editorBracketMatch.background": "#2d2728",
        "editorBracketMatch.border": "#f4bf4f66",
        "focusBorder": "#f4bf4f88",
        "activityBar.background": "#1a1617",
        "activityBar.foreground": "#f4bf4f",
        "activityBar.inactiveForeground": "#7a7577",
        "activityBarBadge.background": "#a82847",
        "activityBarBadge.foreground": "#f5f5f5",
        "sideBar.background": "#1a1617",
        "sideBar.foreground": "#b8b2b3",
        "sideBar.border": "#2d2728",
        "sideBarSectionHeader.background": "#241f20",
        "sideBarSectionHeader.foreground": "#f5f5f5",
        "list.activeSelectionBackground": "#241f20",
        "list.activeSelectionForeground": "#f4bf4f",
        "list.hoverBackground": "#2d2728",
        "list.hoverForeground": "#f5f5f5",
        "list.inactiveSelectionBackground": "#1a1617",
        "list.inactiveSelectionForeground": "#b8b2b3",
        "titleBar.activeBackground": "#2d0a0f",
        "titleBar.activeForeground": "#f5f5f5",
        "titleBar.inactiveBackground": "#1a1617",
        "titleBar.inactiveForeground": "#7a7577",
        "statusBar.background": "#8c1c38",
        "statusBar.foreground": "#f5f5f5",
        "statusBarItem.hoverBackground": "#a82847",
        "statusBarItem.remoteBackground": "#a82847",
        "statusBarItem.remoteForeground": "#f5f5f5",
        "tab.activeBackground": "#1a1617",
        "tab.activeBorderTop": "#f4bf4f",
        "tab.activeForeground": "#f5f5f5",
        "tab.inactiveBackground": "#0f0d0e",
        "tab.inactiveForeground": "#7a7577",
        "tab.border": "#2d2728",
        "tab.hoverBackground": "#241f20",
        "tab.hoverForeground": "#f5f5f5",
        "button.background": "#a82847",
        "button.foreground": "#f5f5f5",
        "button.hoverBackground": "#8c1c38",
        "dropdown.background": "#241f20",
        "dropdown.foreground": "#f5f5f5",
        "dropdown.border": "#2d2728",
        "input.background": "#241f20",
        "input.foreground": "#f5f5f5",
        "input.placeholderForeground": "#7a7577",
        "input.border": "#2d2728",
        "inputOption.activeBorder": "#f4bf4f",
        "scrollbarSlider.background": "#2d2728aa",
        "scrollbarSlider.hoverBackground": "#7a7577aa",
        "scrollbarSlider.activeBackground": "#b8b2b3aa",
        "panel.background": "#0f0d0e",
        "panel.border": "#2d2728",
        "panelTitle.activeForeground": "#f4bf4f",
        "panelTitle.inactiveForeground": "#7a7577",
        "terminal.background": "#0f0d0e",
        "terminal.foreground": "#f5f5f5",
        "terminal.ansiBlack": "#0f0d0e",
        "terminal.ansiRed": "#c23456",
        "terminal.ansiGreen": "#52c41a",
        "terminal.ansiYellow": "#f4bf4f",
        "terminal.ansiBlue": "#b8b2b3",
        "terminal.ansiMagenta": "#a82847",
        "terminal.ansiCyan": "#e6a23c",
        "terminal.ansiWhite": "#f5f5f5",
        "terminal.ansiBrightBlack": "#7a7577",
        "terminal.ansiBrightRed": "#ff4d4f",
        "terminal.ansiBrightGreen": "#73d13d",
        "terminal.ansiBrightYellow": "#ffd666",
        "terminal.ansiBrightBlue": "#d9d9d9",
        "terminal.ansiBrightMagenta": "#c23456",
        "terminal.ansiBrightCyan": "#ffd666",
        "terminal.ansiBrightWhite": "#ffffff"
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "comment",
                    "punctuation.definition.comment"
                ],
                "settings": {
                    "foreground": "#7a7577",
                    "fontStyle": "italic"
                }
            },
            {
                "scope": [
                    "keyword",
                    "storage.type",
                    "storage.modifier"
                ],
                "settings": {
                    "foreground": "#c23456"
                }
            },
            {
                "scope": [
                    "entity.name.function",
                    "support.function",
                    "meta.function-call"
                ],
                "settings": {
                    "foreground": "#f4bf4f"
                }
            },
            {
                "scope": [
                    "entity.name.type",
                    "entity.name.class",
                    "support.type"
                ],
                "settings": {
                    "foreground": "#e6a23c"
                }
            },
            {
                "scope": [
                    "string",
                    "string.quoted"
                ],
                "settings": {
                    "foreground": "#b8b2b3"
                }
            },
            {
                "scope": [
                    "constant.numeric",
                    "constant.language"
                ],
                "settings": {
                    "foreground": "#f4bf4f"
                }
            }
        ]
    },
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "comment": "#7a7577",
            "keyword": "#c23456",
            "function": "#f4bf4f",
            "method": "#f4bf4f",
            "class": "#e6a23c",
            "interface": "#e6a23c",
            "enum": "#e6a23c",
            "enumMember": "#f4bf4f",
            "property": "#b8b2b3",
            "parameter": "#f5f5f5",
            "variable.readonly": "#f4bf4f"
        }
    },
    "files.associations": {
        "*.md": "markdown",
        "*.ts": "typescript",
        "*.tsx": "typescriptreact",
        "*.css": "css"
    },
    "cSpell.words": [
        "archeoares",
        "arrowsize",
        "ATCL",
        "bordercolor",
        "borderwidth",
        "Ciaotickets",
        "COOLDOWN",
        "creds",
        "darkcolor",
        "dotenv",
        "fieldbackground",
        "highlightbackground",
        "highlightcolor",
        "highlightthickness",
        "insertbackground",
        "LANCZOS",
        "lightcolor",
        "Liveticket",
        "padx",
        "pady",
        "qrcodes",
        "quickbar",
        "ROCMA",
        "selectbackground",
        "selectforeground",
        "sparkline",
        "textvariable",
        "TICKETTANDO",
        "topbar",
        "valuenow",
        "Vivaticket"
    ],
    "github-actions.workflows.pinned.workflows": [
        ".github/workflows/sync-deploy-branches.yml",
        ".github/workflows/security.yml"
    ],
    "files.autoSave": "off",
    "editor.aiStats.enabled": true,
    "editor.autoIndentOnPaste": true,
    "git.allowForcePush": true,
    "git.autofetch": "all",
    "git.branchProtection": [
        "main",
        "render/preview"
    ],
    "editor.defaultFormatter": "vscode.markdown-language-features",
    "deno.enablePaths": [
        "supabase/functions"
    ],
    "deno.unstable": true,
    "deno.lint": true,
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    }
}
