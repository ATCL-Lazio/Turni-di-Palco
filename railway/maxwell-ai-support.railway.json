{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install -g @openai/codex && npm install -g gh",
    "watchPatterns": []
  },
  "deploy": {
    "startCommand": "npm run ai:support",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
