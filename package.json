{
  "name": "turni-di-palco-monorepo",
  "private": true,
  "workspaces": [
    "apps/pwa",
    "apps/mobile",
    "apps/reactbricks",
    "apps/control-plane"
  ],
  "scripts": {
    "clean:builds": "node tools/clean-builds.js",
    "dev:pwa": "npm --workspace apps/pwa run dev",
    "dev:pwa:https": "npm --workspace apps/pwa run dev:https",
    "dev:control-plane": "npm --workspace apps/control-plane run dev",
    "dev:control-plane:https": "npm run dev:control-plane",
    "build:pwa": "node tools/update-cache-version.js && npm --workspace apps/pwa run build && node tools/copy-mobile-to-dist.js",
    "preview:pwa": "npm --workspace apps/pwa run preview",
    "start:control-plane": "npm --workspace apps/control-plane run start",
    "test:pwa": "npm --workspace apps/pwa run test",
    "lint": "npm --workspace apps/pwa run lint",
    "format": "npm --workspace apps/pwa run format",
    "dev:mobile": "npm --workspace apps/mobile run dev",
    "build:mobile": "npm --workspace apps/mobile run build && npm run sync:mobile",
    "sync:mobile": "node tools/sync-mobile.js",
    "ai:codex": "node tools/ai-codex.js",
    "ai:support": "node tools/ai-support-server.js",
    "cleanup:events": "node tools/cleanup-old-events.js",
    "keep-alive": "node tools/keep-alive-reciprocal.js",
    "watchdog": "node tools/maxwell-watchdog.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "ajv": "^8.17.1",
    "dotenv": "^16.3.1"
  }
}
