# Supabase client configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dev access gate (comma-separated lists)
VITE_PWA_DEV_ROLES=dev
VITE_PWA_DEV_EMAILS=

# Service worker in dev: set to "true" to register
VITE_SW_DEV=

# Vite dev/preview allowlist (comma-separated)
VITE_ALLOWED_HOSTS=turni-di-palco-fq85.onrender.com

# Dev dashboard -> control plane endpoint
VITE_DEV_CONTROL_PLANE_URL=http://localhost:8787

# Feature flags (comma-separated)
VITE_FEATURE_FLAGS=
VITE_DISABLED_FEATURE_FLAGS=

# Public mode (no auth required)
VITE_PUBLIC_MODE=

# Dev access gate overrides
VITE_DEV_ACCESS_FUNCTION=
VITE_DEV_SESSION_TTL_MS=
VITE_DEV_SESSION_STALE_GRACE_MS=

# Service worker dev cleanup
VITE_SW_DEV_CLEANUP=
