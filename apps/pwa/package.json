{
  "name": "turni-di-palco-pwa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../tools/with-https-env.js vite --host 0.0.0.0 --port 5173 --strictPort --clearScreen false",
    "dev:https": "npm run dev",
    "build": "vite build",
    "preview": "node ../../tools/with-https-env.js node ../../tools/serve-dist.js",
    "preview:https": "npm run preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1-alpha.3",
    "@typescript-eslint/parser": "^8.56.1-alpha.3",
    "@vitest/coverage-v8": "^4.0.16",
    "cross-env": "^7.0.3",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "@types/leaflet": "^1.9.21",
    "@vercel/analytics": "^1.6.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
