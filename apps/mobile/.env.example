VITE_ATCL_PROMO_PROXY_PATH=/api/promotions/proxy
VITE_ATCL_PROMO_USE_LOCAL_PROXY=true
VITE_ATCL_PROMO_ALLOW_EXTERNAL_FALLBACK=false
